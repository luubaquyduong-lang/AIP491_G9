// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Ghi chú (tiếng Việt):
// - Prisma được cấu hình sử dụng MongoDB làm datasource ở trên.
// - Trường `id` của `Chat` và `Message` được ánh xạ tới `_id` (ObjectId)
//   thông qua `@map("_id") @db.ObjectId`, vì vậy document MongoDB
//   sẽ dùng ObjectId thực tế.
// - `Message.chatId` lưu giá trị ObjectId (dạng chuỗi) tham chiếu tới `Chat`.

model Chat {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String

  title String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
}

model Message {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  chatId String @db.ObjectId

  role MessageRole
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Chat Chat @relation(fields: [chatId], references: [id])
}

enum MessageRole {
  user
  assistant
}
